{
  "name": "md-beautify-obsidian",
  "version": "1.0.8",
  "description": "Obsidian plugin for MD Beautify",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production && cp manifest.json src/assets/manifest.json && cp manifest.json dist/manifest.json && cp src/assets/styles.css dist/styles.css",
    "lint": "eslint src/**/*.ts",
    "version": "node version-bump.mjs && git add manifest.json src/assets/manifest.json versions.json && :"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown",
    "md-beautify"
  ],
  "author": "MD Beautify",
  "license": "MIT",
  "dependencies": {
    "@mdb/core": "file:./vendor/mdb-core",
    "katex": "0.16.27",
    "markdown-it": "14.1.0",
    "mermaid": "11.12.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^16.11.21",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "esbuild": "0.14.47",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.1"
  }
}
